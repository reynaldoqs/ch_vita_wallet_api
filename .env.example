# Rails
RAILS_ENV=development
SECRET_KEY_BASE=your_secret_key_base_here

# Server (Puma)
PORT=3000
RAILS_MAX_THREADS=5

# Database
DATABASE_URL=postgres://user:password@localhost:5432/vitawallet_api_development

# Prices API (PriceService)
PRICES_API_URL=https://example.com/api/prices_quote

# CORS (comma-separated origins, or * for all; default *)
# CORS_ORIGINS=*

# JWT token expiration in hours (default 24)
# JWT_EXPIRATION_HOURS=24
